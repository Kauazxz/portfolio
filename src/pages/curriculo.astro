---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Icon from "../components/Icon.astro";
import Button from "../components/Button.astro";

const personal = {
  name: "Kauã Araujo de Souza",
  born: "24/04/2006",
  location: "Santa Lúcia — Vitória/ES",
  phone: "(27) 99661-2446",
  email: "araujokaua8@gmail.com",
  github: { label: "github.com/Kauazxz", href: "https://github.com/Kauazxz" },
  linkedin: {
    label: "/in/kauã-araujo-de-souza",
    href: "https://www.linkedin.com/in/kau%C3%A3-araujo-de-souza/",
  },
};

const experiences = [
  {
    role: "Estagiário — Desenvolvedor Web e Mobile Jr.",
    company: "Vistopred Soluções Ltda",
    period: "Jan 2023 — Fev 2024",
    description:
      "Atuação na construção da presença digital e do produto interno da empresa. Trabalho dividido entre o site institucional, o aplicativo mobile e o atendimento a clientes que utilizavam a plataforma.",
    bullets: [
      "Desenvolvimento do site principal em WordPress, do tema às páginas comerciais",
      "Apoio no desenvolvimento do aplicativo mobile da empresa",
      "Suporte técnico direto aos clientes da plataforma",
    ],
  },
  {
    role: "Estagiário",
    company: "Eseel Engenharia",
    period: "Jul 2021 — Jan 2023",
    description:
      "Primeira experiência profissional, ainda durante o ensino médio técnico. Rotina ligada a documentação técnica, ensaios em campo e suporte a projetos de engenharia.",
    bullets: [
      "Elaboração de relatórios técnicos e registro fotográfico de ensaios",
      "Participação em projetos utilizando AutoCAD",
      "Rotina administrativa com Pacote Office",
    ],
  },
];

const education = [
  {
    title: "Bacharelado em Ciência da Computação",
    where: "Universidade Vila Velha",
    period: "2024 — 2027 (5º período)",
    note: "Em andamento.",
  },
  {
    title: "Ensino Médio Integrado — Técnico em Informática",
    where: "EEEM Irmã Maria Horta",
    period: "2021 — 2023",
    note: "Formação técnica concluída.",
  },
];

const courses = [
  {
    title: "Java Fundamentals — Português",
    issuer: "Oracle Academy",
    period: "Ago 2025 — Dez 2025",
  },
  {
    title: "Database Foundations — Português",
    issuer: "Oracle Academy",
    period: "Mar 2024 — Jun 2024",
  },
  {
    title: "Inglês — Intermediário (W4)",
    issuer: "Wizard by Pearson",
    period: "2023 — 2024",
  },
];

const skillGroups = [
  {
    title: "Desenvolvimento",
    items: [
      "HTML, CSS e JavaScript",
      "TypeScript",
      "Dart / Flutter",
      "C",
      "WordPress",
      "Construção de software para web",
    ],
  },
  {
    title: "Dados & Sistemas",
    items: [
      "Design e desenvolvimento de banco de dados",
      "Sistemas operacionais",
      "Arquitetura, montagem, instalação e manutenção de computadores",
      "Segurança da informação e ferramentas de suporte",
    ],
  },
  {
    title: "Design & Conteúdo",
    items: [
      "Experiência e interface com o usuário",
      "Canva",
      "Gerenciamento de transmissão ao vivo",
    ],
  },
  {
    title: "Marketing Digital",
    items: [
      "Gestão de tráfego pago — Meta Ads",
      "Gestão de tráfego pago — Google Ads",
    ],
  },
];
---

<Base
  title="Currículo — Kauã Araujo de Souza"
  description="Currículo completo de Kauã Araujo de Souza: experiência profissional, formação acadêmica, cursos e habilidades."
>
  <Section id="top">
    <a
      href="/#curriculo"
      class="mb-10 inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.18em] text-fg-dim transition-colors hover:text-fg"
    >
      <Icon name="arrow-right" size={12} class="-scale-x-100" />
      Voltar pro portfólio
    </a>

    <header class="reveal mb-14 flex flex-col gap-6 border-b border-border pb-12">
      <span
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.18em] text-accent"
      >
        <span class="size-1 rounded-full bg-accent"></span>
        Currículo
      </span>
      <h1
        class="text-balance text-4xl font-bold tracking-tight text-fg md:text-5xl lg:text-6xl"
      >
        {personal.name}
      </h1>
      <p class="max-w-2xl text-pretty text-base text-fg-muted md:text-lg">
        Estudante de Ciência da Computação focado em desenvolvimento web e
        mobile. Atuo desde 2021 em estágios na área técnica e venho construindo
        projetos próprios em paralelo aos estudos.
      </p>

      <dl
        class="mt-4 grid gap-x-8 gap-y-3 text-sm md:grid-cols-2 lg:grid-cols-3"
      >
        <div class="flex flex-col">
          <dt
            class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-fg-dim"
          >
            Local
          </dt>
          <dd class="text-fg">{personal.location}</dd>
        </div>
        <div class="flex flex-col">
          <dt
            class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-fg-dim"
          >
            Nascimento
          </dt>
          <dd class="text-fg">{personal.born}</dd>
        </div>
        <div class="flex flex-col">
          <dt
            class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-fg-dim"
          >
            Telefone
          </dt>
          <dd class="text-fg">{personal.phone}</dd>
        </div>
        <div class="flex flex-col">
          <dt
            class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-fg-dim"
          >
            Email
          </dt>
          <dd>
            <a
              href={`mailto:${personal.email}`}
              class="text-fg hover:text-accent-hover"
            >
              {personal.email}
            </a>
          </dd>
        </div>
        <div class="flex flex-col">
          <dt
            class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-fg-dim"
          >
            GitHub
          </dt>
          <dd>
            <a
              href={personal.github.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-fg hover:text-accent-hover"
            >
              {personal.github.label}
            </a>
          </dd>
        </div>
        <div class="flex flex-col">
          <dt
            class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-fg-dim"
          >
            LinkedIn
          </dt>
          <dd>
            <a
              href={personal.linkedin.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-fg hover:text-accent-hover"
            >
              {personal.linkedin.label}
            </a>
          </dd>
        </div>
      </dl>

      <div class="mt-2 flex flex-wrap gap-3">
        <Button href="/curriculo.pdf" size="md">
          <Icon name="arrow-down" size={14} />
          Baixar em PDF
        </Button>
        <Button href="/#contato" variant="secondary" size="md">
          <Icon name="mail" size={14} />
          Falar comigo
        </Button>
      </div>
    </header>

    <div class="grid gap-16 lg:grid-cols-[1.4fr_1fr]">
      <div class="flex flex-col gap-14">
        <section class="reveal flex flex-col gap-6">
          <header class="flex flex-col gap-1">
            <span
              class="font-mono text-xs uppercase tracking-[0.18em] text-fg-dim"
            >
              01 — Experiência profissional
            </span>
            <h2 class="text-2xl font-semibold text-fg md:text-3xl">
              Onde passei
            </h2>
          </header>

          <ol class="flex flex-col gap-5">
            {
              experiences.map((item, index) => (
                <li
                  class="reveal rounded-xl border border-border bg-surface/40 p-6 transition-colors hover:border-border-strong"
                  style={`--i: ${index + 1}`}
                >
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                    <h3 class="text-base font-semibold text-fg">{item.role}</h3>
                    <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-fg-dim">
                      {item.period}
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-accent">{item.company}</p>
                  <p class="mt-3 text-sm leading-relaxed text-fg-muted">
                    {item.description}
                  </p>
                  <ul class="mt-4 flex flex-col gap-2 text-sm leading-relaxed text-fg-muted">
                    {item.bullets.map((b) => (
                      <li class="flex items-start gap-2.5">
                        <Icon
                          name="check"
                          size={14}
                          class="mt-1 shrink-0 text-accent"
                        />
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                </li>
              ))
            }
          </ol>
        </section>

        <section class="reveal flex flex-col gap-6">
          <header class="flex flex-col gap-1">
            <span
              class="font-mono text-xs uppercase tracking-[0.18em] text-fg-dim"
            >
              02 — Formação acadêmica
            </span>
            <h2 class="text-2xl font-semibold text-fg md:text-3xl">
              O que estudei
            </h2>
          </header>

          <ul class="flex flex-col gap-4">
            {
              education.map((item, index) => (
                <li
                  class="reveal rounded-xl border border-border bg-surface/40 p-5"
                  style={`--i: ${index + 1}`}
                >
                  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                    <h3 class="text-base font-semibold text-fg">
                      {item.title}
                    </h3>
                    <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-fg-dim">
                      {item.period}
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-accent">{item.where}</p>
                  <p class="mt-2 text-sm text-fg-muted">{item.note}</p>
                </li>
              ))
            }
          </ul>
        </section>
      </div>

      <div class="flex flex-col gap-14">
        <section class="reveal flex flex-col gap-6">
          <header class="flex flex-col gap-1">
            <span
              class="font-mono text-xs uppercase tracking-[0.18em] text-fg-dim"
            >
              03 — Cursos e idiomas
            </span>
            <h2 class="text-2xl font-semibold text-fg md:text-3xl">
              Certificações
            </h2>
          </header>

          <ul class="flex flex-col gap-3">
            {
              courses.map((c) => (
                <li class="rounded-xl border border-border bg-surface/40 p-4">
                  <h3 class="text-sm font-semibold text-fg">{c.title}</h3>
                  <p class="mt-1 text-sm text-accent">{c.issuer}</p>
                  <p class="mt-1 font-mono text-[0.7rem] uppercase tracking-[0.14em] text-fg-dim">
                    {c.period}
                  </p>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="reveal flex flex-col gap-6">
          <header class="flex flex-col gap-1">
            <span
              class="font-mono text-xs uppercase tracking-[0.18em] text-fg-dim"
            >
              04 — Habilidades
            </span>
            <h2 class="text-2xl font-semibold text-fg md:text-3xl">
              O que sei fazer
            </h2>
          </header>

          <div class="flex flex-col gap-5">
            {
              skillGroups.map((group) => (
                <div class="rounded-xl border border-border bg-surface/40 p-5">
                  <h3 class="mb-3 text-sm font-semibold text-fg">
                    {group.title}
                  </h3>
                  <ul class="flex flex-col gap-1.5 text-sm text-fg-muted">
                    {group.items.map((item) => (
                      <li class="flex items-start gap-2">
                        <span
                          class="mt-2 inline-block size-1 shrink-0 rounded-full bg-fg-dim"
                          aria-hidden="true"
                        />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </Section>
</Base>
