---
import SectionHeader from "./SectionHeader.astro";

const steps = [
  {
    number: "01",
    title: "Entendimento",
    body: "Antes de codar, entendo o objetivo, o público, as telas necessárias e o que realmente precisa ser resolvido.",
  },
  {
    number: "02",
    title: "Estrutura",
    body: "Organizo a arquitetura, componentes, design system, fluxos e prioridades da primeira versão.",
  },
  {
    number: "03",
    title: "Desenvolvimento",
    body: "Transformo o planejamento em interface e funcionalidade, mantendo código limpo e responsivo.",
  },
  {
    number: "04",
    title: "Entrega",
    body: "Faço deploy, reviso detalhes, ajusto performance e deixo o projeto preparado para evoluir.",
  },
];
---

<section id="processo" class="section bg-bg-2/40">
  <div class="container">
    <SectionHeader
      eyebrow="Processo"
      title="Meu processo para tirar uma ideia do papel."
      subtitle="Gosto de construir com clareza: entender primeiro, desenhar o caminho, desenvolver com organização e melhorar depois da entrega."
    />

    <ol class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, i) => (
          <li
            class="card card-hover reveal flex-col"
            style={`transition-delay: ${i * 60}ms`}
          >
            <span class="font-mono text-sm font-medium text-accent">
              {step.number}
            </span>
            <h3 class="text-base font-semibold text-fg">{step.title}</h3>
            <p class="text-sm leading-relaxed text-muted">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
