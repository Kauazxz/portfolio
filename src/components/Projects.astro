---
import Section from "./Section.astro";
import SectionHeader from "./SectionHeader.astro";
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    title: "VistoPred",
    category: "Dev" as const,
    summary:
      "Plataforma completa de inspeção e manutenção predial. Centraliza cadastros, checklists, controle de estoque, geração de relatórios e validação de documentos em um único painel administrativo.",
    context:
      "Concepção, arquitetura, desenvolvimento full-stack e modelagem dos fluxos de dados.",
    tags: ["Next.js", "TypeScript", "PostgreSQL", "Tailwind"],
    year: "2025",
    featured: true,
  },
  {
    title: "L.A.D.P.A.R Tecnologia",
    category: "Design" as const,
    summary:
      "Site institucional e estrutura digital completa para fabricante de desidratadores industriais. Catálogo organizado por linha de produto, identidade visual coerente e páginas comerciais com caminho claro até o contato.",
    context: "Estratégia digital, design de interface e desenvolvimento.",
    tags: ["Astro", "Tailwind", "CMS"],
    year: "2024",
  },
  {
    title: "Portfólio pessoal",
    category: "Dev" as const,
    summary:
      "Este site. Construído do zero com a mesma stack e exigência que aplico em projetos de cliente. Estático, rápido, dark theme, animações sutis e arquitetura componentizada.",
    context: "Design, desenvolvimento e copy — projeto próprio.",
    tags: ["Astro", "React", "Tailwind", "TypeScript"],
    year: "2026",
  },
  {
    title: "Validação de documentos",
    category: "IA" as const,
    summary:
      "Sistemas administrativos para cadastro de prestadores, upload e validação automatizada de documentos, com painel de aprovação para gestores, controle de status e trilha de auditoria.",
    context: "Modelagem do fluxo de aprovação e desenvolvimento full-stack.",
    tags: ["Node.js", "PostgreSQL", "Webhooks"],
    year: "2024",
  },
];
---

<Section id="projetos">
  <SectionHeader
    eyebrow="Projetos"
    title="Trabalhos selecionados."
    lead="Uma amostra do que construí recentemente — produtos próprios, sistemas para clientes e presença digital para marcas."
  />

  <div class="project-grid grid gap-5 md:grid-cols-2">
    {projects.map((project, index) => <ProjectCard {...project} index={index} />)}
  </div>
</Section>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".project-grid .tilt");
  const supportsHover = window.matchMedia(
    "(hover: hover) and (pointer: fine)",
  ).matches;
  const reduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (supportsHover && !reduced) {
    cards.forEach((card) => {
      let raf = 0;
      const onMove = (e: PointerEvent) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          card.style.transform = `perspective(900px) rotateY(${x * 4}deg) rotateX(${-y * 4}deg)`;
        });
      };
      const onEnter = () => card.classList.add("is-tilting");
      const onLeave = () => {
        card.classList.remove("is-tilting");
        cancelAnimationFrame(raf);
        card.style.transform = "";
      };
      card.addEventListener("pointerenter", onEnter);
      card.addEventListener("pointermove", onMove);
      card.addEventListener("pointerleave", onLeave);
    });
  }
</script>
