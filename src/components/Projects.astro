---
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon.astro";
import { projects } from "../data/projects";

// Home mostra só 3 projetos como preview — a página /projetos tem todos.
const preview = projects.slice(0, 3);
---

<section id="projetos" class="section">
  <div class="site-container">
    <SectionHeader
      eyebrow="Projetos em destaque"
      title="Trabalhos selecionados e estudos"
      subtitle="Alguns trabalhos e estudos que mostram minha forma de pensar, construir e entregar soluções digitais."
    />

    <div
      class:list={[
        "grid gap-4",
        preview.length === 1 && "mx-auto max-w-md",
        preview.length === 2 && "md:grid-cols-2",
        preview.length >= 3 && "md:grid-cols-2 lg:grid-cols-3",
      ]}
    >
      {
        preview.map((project, i) => (
          <article
            class="card card-accent-hover reveal group"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="relative flex aspect-[16/9] items-center justify-center overflow-hidden rounded-lg border border-border bg-bg-2 text-fg-dim transition-colors group-hover:border-border-strong">
              {project.previewImage ? (
                <img
                  src={project.previewImage}
                  alt={`Preview do projeto ${project.title}`}
                  class="size-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span class="font-mono text-xs uppercase tracking-[0.18em]">
                  Preview
                </span>
              )}
            </div>

            <h3 class="text-lg font-semibold text-fg">{project.title}</h3>
            <p class="text-sm leading-relaxed text-muted">
              {project.description}
            </p>

            <ul class="flex flex-wrap gap-1.5">
              {project.tags.slice(0, 4).map((tag) => (
                <li class="tech-tag">{tag}</li>
              ))}
            </ul>

            <div class="mt-2 flex flex-wrap items-center gap-3 pt-2">
              <a
                href={project.caseUrl ?? `/projetos#${project.id}`}
                class="inline-flex items-center gap-1.5 text-sm font-medium text-fg transition-colors hover:text-accent"
              >
                Ver detalhes
                <Icon name="arrow-up-right" size={14} />
              </a>
              {project.codeUrl && (
                <a
                  href={project.codeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm text-muted transition-colors hover:text-fg"
                >
                  Ver código
                  <Icon name="arrow-up-right" size={14} />
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-10 flex justify-center">
      <a href="/projetos" class="button button-secondary">
        Ver matriz completa de projetos
        <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</section>
