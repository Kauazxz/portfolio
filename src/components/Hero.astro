---
import Icon from "./Icon.astro";
---

<section id="top" class="relative">
  <div class="site-container pt-8 pb-6 md:pt-12 md:pb-8">
    <div
      class="grid items-center gap-6 lg:grid-cols-[1.3fr_1fr] lg:gap-12"
    >
      <div class="reveal flex flex-col gap-4">
        <span class="badge w-fit">
          <span class="badge-dot"></span>
          Disponível para novos projetos
        </span>

        <h1 class="title-xl">
          Desenvolvedor full-stack com
          <span class="accent-text">olhar de design</span>
          e
          <span class="accent-text">cabeça de produto</span>
        </h1>

        <p class="subtitle">
          Crio sites, sistemas web e interfaces modernas com foco em
          performance, clareza visual e experiência do usuário — do primeiro
          rascunho ao deploy.
        </p>

        <div class="flex flex-wrap items-center gap-2.5">
          <a href="#projetos" class="button button-primary">
            Ver projetos
            <Icon name="arrow-right" size={15} />
          </a>
          <a href="#contato" class="button button-secondary">
            Falar comigo
          </a>
        </div>
      </div>

      <div
        class="reveal relative mx-auto w-full max-w-[180px] sm:max-w-[210px] lg:mx-0 lg:ml-auto lg:max-w-[300px]"
        style="transition-delay: 120ms"
      >
        <figure
          class="relative aspect-[4/5] overflow-hidden rounded-2xl border border-border-strong bg-surface"
          style="max-height: 560px"
        >
          {/* TODO: trocar /me.webp pela foto definitiva quando tiver */}
          <img
            src="/me.webp"
            alt="Retrato de Kauã Araujo"
            class="size-full object-cover"
            style="object-position: center top"
            loading="eager"
            decoding="async"
          />
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-bg/60 via-transparent to-transparent"
          >
          </div>

          <figcaption
            class="absolute bottom-2.5 left-2.5 inline-flex items-center gap-2 rounded-md border border-border-strong bg-bg/80 px-2 py-1 font-mono text-[0.7rem] text-fg backdrop-blur-sm"
          >
            <span class="size-1.5 rounded-full bg-accent"></span>
            Kauã Araujo · Vitória, ES
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>
