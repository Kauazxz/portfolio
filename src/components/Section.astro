---
interface Props {
  id?: string;
  class?: string;
  bleed?: boolean;
}

const { id, class: className = "", bleed = false } = Astro.props;
---

<section id={id} class:list={["relative py-20 md:py-28", className]}>
  {
    bleed ? (
      <slot />
    ) : (
      <div class="container-page">
        <slot />
      </div>
    )
  }
</section>
