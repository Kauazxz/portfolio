---
import Section from "./Section.astro";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon.astro";

const groups = [
  {
    icon: "code" as const,
    color: "text-sky-400",
    title: "Front-end",
    tags: [
      "HTML",
      "CSS",
      "JavaScript",
      "TypeScript",
      "React",
      "Next.js",
      "Astro",
      "Tailwind CSS",
    ],
  },
  {
    icon: "layout" as const,
    color: "text-emerald-400",
    title: "Back-end & Dados",
    tags: [
      "Node.js",
      "APIs REST",
      "PostgreSQL",
      "MySQL",
      "Supabase",
      "Webhooks",
    ],
  },
  {
    icon: "palette" as const,
    color: "text-fuchsia-400",
    title: "Design & UI",
    tags: [
      "Figma",
      "Design Systems",
      "Prototipagem",
      "Identidade visual",
      "Tipografia",
      "Acessibilidade",
    ],
  },
  {
    icon: "compass" as const,
    color: "text-amber-400",
    title: "Ferramentas & Metodologias",
    tags: [
      "Git",
      "GitHub",
      "VS Code",
      "Vercel",
      "Vite",
      "Mobile-first",
      "Code review",
    ],
  },
];

const soft = [
  "Comunicação clara com cliente não-técnico",
  "Organização e cumprimento de prazos",
  "Pensamento de produto, não só execução",
  "Aprendizado rápido de novas stacks",
  "Atenção a detalhes visuais e técnicos",
  "Autonomia para tocar projeto do zero",
];
---

<Section id="stack">
  <SectionHeader
    eyebrow="Stack"
    title="Ferramentas e linguagens do dia a dia."
    lead="Stack centrada em web moderna, com atenção igual ao back-end, design e ao processo por trás de cada entrega."
  />

  <div class="grid gap-5 md:grid-cols-2">
    {
      groups.map((group, index) => (
        <div
          class="reveal rounded-xl border border-border bg-surface/40 p-6 transition-colors hover:border-border-strong"
          style={`--i: ${index}`}
        >
          <div class="mb-5 flex items-center gap-3">
            <span
              class:list={[
                "flex size-9 items-center justify-center rounded-lg border border-border bg-surface-2",
                group.color,
              ]}
            >
              <Icon name={group.icon} size={18} />
            </span>
            <h3 class="text-base font-semibold text-fg">{group.title}</h3>
          </div>
          <ul class="flex flex-wrap gap-1.5">
            {group.tags.map((tag) => (
              <li class="rounded-md border border-border bg-bg/60 px-2.5 py-1 font-mono text-[0.75rem] text-fg-muted transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/60 hover:text-fg hover:shadow-[0_2px_12px_-4px_rgba(255,51,68,0.35)]">
                {tag}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div
    class="reveal mt-10 rounded-xl border border-border bg-surface/30 p-6 md:p-8"
    style="--i: 4"
  >
    <h3
      class="mb-5 flex items-center gap-2 font-mono text-xs uppercase tracking-[0.18em] text-fg-dim"
    >
      <span class="size-1 rounded-full bg-fg-dim"></span>
      Além do código
    </h3>
    <ul class="grid gap-x-6 gap-y-3 text-sm text-fg-muted md:grid-cols-2">
      {
        soft.map((item) => (
          <li class="flex items-start gap-2.5">
            <Icon
              name="check"
              size={16}
              class="mt-0.5 shrink-0 text-accent"
            />
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
