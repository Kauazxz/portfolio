---
interface Props {
  name:
    | "html"
    | "css"
    | "javascript"
    | "typescript"
    | "react"
    | "next"
    | "tailwind"
    | "node"
    | "python"
    | "fastapi"
    | "postgresql"
    | "firebase"
    | "mongodb"
    | "git"
    | "github"
    | "docker"
    | "vercel"
    | "figma";
  size?: number;
  class?: string;
}

const { name, size = 26, class: className = "" } = Astro.props;
const base = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  class: className,
  "aria-hidden": true,
};
---

{
  name === "html" && (
    <svg
      {...base}
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M3.5 3h17l-1.55 16.5L12 21.5l-7-2L3.5 3z" />
      <path d="M7.7 8h8.8M7.7 12.2h8M9.4 17l2.6.7 2.6-.7.3-3" />
    </svg>
  )
}
{
  name === "css" && (
    <svg
      {...base}
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M3.5 3h17l-1.55 16.5L12 21.5l-7-2L3.5 3z" />
      <path d="M16.5 8H8l.3 2.5h7.9l-.4 4-3.4.9-3.4-.9-.2-2" />
    </svg>
  )
}
{
  name === "javascript" && (
    <svg {...base} fill="none">
      <rect
        x="2.5"
        y="2.5"
        width="19"
        height="19"
        rx="3"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      />
      <text
        x="12"
        y="16.2"
        font-family="JetBrains Mono, monospace"
        font-size="8"
        font-weight="700"
        text-anchor="middle"
        fill="currentColor"
      >
        JS
      </text>
    </svg>
  )
}
{
  name === "typescript" && (
    <svg {...base} fill="none">
      <rect
        x="2.5"
        y="2.5"
        width="19"
        height="19"
        rx="3"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      />
      <text
        x="12"
        y="16.2"
        font-family="JetBrains Mono, monospace"
        font-size="8"
        font-weight="700"
        text-anchor="middle"
        fill="currentColor"
      >
        TS
      </text>
    </svg>
  )
}
{
  name === "react" && (
    <svg {...base} fill="none" stroke="currentColor" stroke-width="1.3">
      <circle cx="12" cy="12" r="1.6" fill="currentColor" />
      <ellipse cx="12" cy="12" rx="10" ry="3.8" />
      <ellipse
        cx="12"
        cy="12"
        rx="10"
        ry="3.8"
        transform="rotate(60 12 12)"
      />
      <ellipse
        cx="12"
        cy="12"
        rx="10"
        ry="3.8"
        transform="rotate(-60 12 12)"
      />
    </svg>
  )
}
{
  name === "next" && (
    <svg {...base} fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="9.5" />
