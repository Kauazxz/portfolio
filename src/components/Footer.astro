---
import Icon from "./Icon.astro";

const year = new Date().getFullYear();

const isHome = Astro.url.pathname === "/";
const prefix = isHome ? "" : "/";

const sitemap = [
  { label: "Sobre", href: "/sobre" },
  { label: "Serviços", href: "/servicos" },
  { label: "Projetos", href: "/projetos" },
  { label: "Contato", href: `${prefix}#contato` },
];

const social = [
  {
    label: "GitHub",
    icon: "github" as const,
    href: "https://github.com/Kauazxz",
  },
  {
    label: "LinkedIn",
    icon: "linkedin" as const,
    href: "https://www.linkedin.com/in/kau%C3%A3-araujo-de-souza/",
  },
  {
    label: "Email",
    icon: "mail" as const,
    href: "mailto:araujokaua8@gmail.com",
  },
  {
    label: "WhatsApp",
    icon: "whatsapp" as const,
    href: "https://wa.me/5527996612446",
  },
];
---

<footer class="border-t border-border bg-bg-2/40">
  <div class="site-container py-10 md:py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr] md:gap-12">
      <div class="flex max-w-md flex-col gap-4">
        <a
          href="#top"
          class="font-semibold tracking-tight text-fg transition-colors hover:text-accent-hover"
          aria-label="Início"
        >
          kauã<span class="text-accent">.</span>
        </a>
        <p class="text-sm leading-relaxed text-muted">
          Desenvolvedor full-stack focado em criar sites, sistemas web e
          interfaces modernas com performance, clareza e bom design.
        </p>
      </div>

      <nav aria-label="Mapa do site" class="flex flex-col gap-3">
        <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-dim">
          Navegação
        </h3>
        <ul class="flex flex-col gap-2">
          {
            sitemap.map((item) => (
              <li>
                <a href={item.href} class="link text-sm">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex flex-col gap-3">
        <h3 class="font-mono text-xs uppercase tracking-[0.16em] text-dim">
          Redes
        </h3>
        <ul class="flex flex-col gap-2">
          {
            social.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.label !== "Email" ? "_blank" : undefined}
                  rel={
                    item.label !== "Email" ? "noopener noreferrer" : undefined
                  }
                  class="link inline-flex items-center gap-2 text-sm"
                >
                  <Icon name={item.icon} size={14} />
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-border pt-8 text-xs text-dim md:flex-row md:items-center md:justify-between"
    >
      <p>© {year} Kauã Araujo de Souza. Todos os direitos reservados.</p>
      <p>Criado com código, design e atenção aos detalhes.</p>
    </div>
  </div>
</footer>
