---
import Section from "./Section.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";

const email = "araujokaua8@gmail.com";

const channels = [
  {
    name: "GitHub",
    icon: "github" as const,
    href: "https://github.com/Kauazxz",
    handle: "@Kauazxz",
  },
  {
    name: "LinkedIn",
    icon: "linkedin" as const,
    href: "https://www.linkedin.com/in/kau%C3%A3-araujo-de-souza/",
    handle: "/in/kauã-araujo-de-souza",
  },
  {
    name: "Email",
    icon: "mail" as const,
    href: `mailto:${email}`,
    handle: email,
  },
];
---

<Section id="contato">
  <div class="relative overflow-hidden rounded-2xl border border-border bg-surface/50 p-8 md:p-14">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -right-20 -top-20 size-72 rounded-full bg-accent/[0.07] blur-3xl"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -bottom-20 -left-20 size-72 rounded-full bg-accent/[0.05] blur-3xl"
    >
    </div>

    <div class="relative flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
      <div class="reveal flex max-w-xl flex-col gap-5">
        <span
          class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.18em] text-accent"
        >
          <span class="size-1 rounded-full bg-accent"></span>
          Contato
        </span>
        <h2
          class="text-balance text-3xl font-semibold tracking-tight text-fg md:text-5xl"
        >
          Tem um projeto em mente? <br />
          <span class="text-fg-muted">Vamos conversar.</span>
        </h2>
        <p class="text-base text-fg-muted">
          Recebo bem novos projetos, parcerias e conversas sobre produto, IA
          ou design. Resposta em até 24h em dias úteis.
        </p>

        <div class="mt-2 flex flex-wrap items-center gap-3">
          <Button href={`mailto:${email}`} size="lg">
            <Icon name="mail" size={16} />
            Enviar email
          </Button>
          <button
            type="button"
            id="copy-email"
            class="group inline-flex items-center gap-2 rounded-md border border-border-strong bg-surface px-4 py-2.5 font-mono text-sm text-fg-muted transition-colors hover:border-fg-muted hover:bg-surface-2 hover:text-fg focus-visible:outline-none"
            data-email={email}
            aria-label="Copiar endereço de email"
          >
            <span class="copy-text">{email}</span>
            <Icon name="copy" size={14} class="copy-icon" />
            <Icon
              name="check"
              size={14}
              class="check-icon hidden text-accent"
            />
          </button>
        </div>
      </div>

      <ul class="grid w-full gap-3 sm:grid-cols-3 lg:w-auto lg:max-w-md">
        {
          channels.map((channel, index) => (
            <li class="reveal" style={`--i: ${index + 1}`}>
              <a
                href={channel.href}
                target={channel.name !== "Email" ? "_blank" : undefined}
                rel={
                  channel.name !== "Email" ? "noopener noreferrer" : undefined
                }
                class="group flex h-full flex-col gap-2 rounded-xl border border-border bg-bg/50 p-4 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:bg-surface hover:shadow-[0_8px_24px_-12px_rgba(255,51,68,0.35)]"
              >
                <span class="flex items-center justify-between text-fg-muted transition-colors group-hover:text-accent-hover">
                  <Icon name={channel.icon} size={18} />
                  <Icon
                    name="arrow-up-right"
                    size={14}
                    class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                  />
                </span>
                <div class="flex flex-col">
                  <span class="text-sm font-medium text-fg">
                    {channel.name}
                  </span>
                  <span class="truncate font-mono text-xs text-fg-dim">
                    {channel.handle}
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Section>

<script>
  const btn = document.getElementById("copy-email");
  if (btn) {
    const email = btn.getAttribute("data-email") ?? "";
    const copyIcon = btn.querySelector(".copy-icon");
    const checkIcon = btn.querySelector(".check-icon");
    const text = btn.querySelector(".copy-text");
    const original = text?.textContent ?? "";

    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        if (text) text.textContent = "Copiado";
        window.setTimeout(() => {
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          if (text) text.textContent = original;
        }, 1800);
      } catch {
        /* clipboard indisponível */
      }
    });
  }
</script>
