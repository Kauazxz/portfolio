---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  external?: boolean;
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  class: className = "",
  ariaLabel,
} = Astro.props;

const base =
  "group inline-flex items-center justify-center gap-2 font-medium rounded-md transition-[background-color,color,border-color,transform] duration-150 ease-[var(--ease-enter)] active:scale-[0.98] focus-visible:outline-none";

const variants = {
  primary:
    "bg-accent text-white hover:bg-accent-hover shadow-[0_0_0_1px_rgba(255,99,99,0.4),0_8px_24px_-12px_rgba(255,51,68,0.6)]",
  secondary:
    "border border-border-strong bg-surface text-fg hover:border-fg-muted hover:bg-surface-2",
  ghost: "text-fg-muted hover:bg-surface hover:text-fg",
};

const sizes = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-5 py-2.5 text-sm",
  lg: "px-6 py-3 text-[0.95rem]",
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
const linkRel = external ? "noopener noreferrer" : undefined;
const linkTarget = external ? "_blank" : undefined;
---

{
  href ? (
    <a
      href={href}
      class={classes}
      target={linkTarget}
      rel={linkRel}
      aria-label={ariaLabel}
    >
      <slot />
    </a>
  ) : (
    <button type="button" class={classes} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}
