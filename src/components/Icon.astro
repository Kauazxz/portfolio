---
interface Props {
  name:
    | "arrow-right"
    | "arrow-up-right"
    | "arrow-down"
    | "code"
    | "palette"
    | "sparkles"
    | "video"
    | "github"
    | "linkedin"
    | "mail"
    | "external-link"
    | "check"
    | "copy"
    | "smartphone"
    | "zap"
    | "layout"
    | "chart"
    | "compass"
    | "shield";
  size?: number;
  class?: string;
}

const { name, size = 20, class: className = "" } = Astro.props;
const stroke = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.75",
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  class: className,
  "aria-hidden": true,
};
const filled = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  fill: "currentColor",
  class: className,
  "aria-hidden": true,
};
---

{
  name === "arrow-right" && (
    <svg {...stroke}>
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  )
}
{
  name === "arrow-up-right" && (
    <svg {...stroke}>
      <path d="M7 17L17 7M8 7h9v9" />
    </svg>
  )
}
{
  name === "arrow-down" && (
    <svg {...stroke}>
      <path d="M12 5v14M6 13l6 6 6-6" />
    </svg>
  )
}
{
  name === "code" && (
    <svg {...stroke}>
      <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" />
