---
interface Props {
  name:
    | "arrow-right"
    | "arrow-up-right"
    | "arrow-down"
    | "code"
    | "layout"
    | "server"
    | "database"
    | "wrench"
    | "palette"
    | "github"
    | "linkedin"
    | "mail"
    | "whatsapp"
    | "check"
    | "menu"
    | "close";
  size?: number;
  class?: string;
}

const { name, size = 18, class: className = "" } = Astro.props;

const stroke = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": 1.75,
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  class: className,
  "aria-hidden": true,
};

const filled = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  fill: "currentColor",
  class: className,
  "aria-hidden": true,
};
---

{
  name === "arrow-right" && (
    <svg {...stroke}>
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  )
}
{
  name === "arrow-up-right" && (
    <svg {...stroke}>
      <path d="M7 17 17 7M8 7h9v9" />
    </svg>
  )
}
{
  name === "arrow-down" && (
    <svg {...stroke}>
      <path d="M12 5v14M6 13l6 6 6-6" />
    </svg>
  )
}
{
  name === "code" && (
    <svg {...stroke}>
      <path d="m16 18 6-6-6-6M8 6l-6 6 6 6" />
    </svg>
  )
}
{
  name === "layout" && (
    <svg {...stroke}>
      <rect width="18" height="18" x="3" y="3" rx="2" />
      <path d="M3 9h18M9 21V9" />
    </svg>
  )
}
{
  name === "server" && (
    <svg {...stroke}>
      <rect width="20" height="8" x="2" y="2" rx="2" />
      <rect width="20" height="8" x="2" y="14" rx="2" />
      <path d="M6 6h.01M6 18h.01" />
    </svg>
  )
}
{
  name === "database" && (
    <svg {...stroke}>
      <ellipse cx="12" cy="5" rx="9" ry="3" />
      <path d="M3 5v14a9 3 0 0 0 18 0V5" />
      <path d="M3 12a9 3 0 0 0 18 0" />
    </svg>
  )
}
{
  name === "wrench" && (
    <svg {...stroke}>
      <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5z" />
    </svg>
  )
}
{
  name === "palette" && (
    <svg {...stroke}>
      <circle cx="13.5" cy="6.5" r=".5" fill="currentColor" />
      <circle cx="17.5" cy="10.5" r=".5" fill="currentColor" />
      <circle cx="8.5" cy="7.5" r=".5" fill="currentColor" />
      <circle cx="6.5" cy="12.5" r=".5" fill="currentColor" />
      <path d="M12 2a10 10 0 1 0 0 20 1.7 1.7 0 0 0 1.7-1.7c0-.4-.2-.8-.4-1.1-.3-.3-.5-.7-.5-1.1a1.7 1.7 0 0 1 1.7-1.7H17a5.5 5.5 0 0 0 5.5-5.6C22 6 17.5 2 12 2z" />
    </svg>
  )
}
{
  name === "github" && (
    <svg {...filled}>
      <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3" />
    </svg>
  )
}
{
  name === "linkedin" && (
    <svg {...filled}>
      <path d="M20.4 20.5h-3.6V15c0-1.3 0-3-1.8-3s-2.2 1.4-2.2 2.9v5.6H9.3V9h3.4v1.6h.1c.5-.9 1.6-1.9 3.4-1.9 3.6 0 4.3 2.4 4.3 5.4v6.4ZM5.3 7.4a2.1 2.1 0 1 1 0-4.1 2.1 2.1 0 0 1 0 4.1Zm1.8 13.1H3.6V9h3.5v11.5ZM22.2 0H1.8C.8 0 0 .8 0 1.7v20.5C0 23.2.8 24 1.8 24h20.4c1 0 1.8-.8 1.8-1.7V1.7C24 .8 23.2 0 22.2 0Z" />
    </svg>
  )
}
{
  name === "mail" && (
    <svg {...stroke}>
      <rect width="20" height="16" x="2" y="4" rx="2" />
      <path d="m22 7-9 5.7a2 2 0 0 1-2 0L2 7" />
    </svg>
  )
}
{
  name === "whatsapp" && (
    <svg {...filled}>
      <path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.3.2-.6.1a8.3 8.3 0 0 1-4-3.5c-.3-.5.3-.5.9-1.6a.6.6 0 0 0 0-.6c-.1-.1-.7-1.6-.9-2.2-.2-.6-.4-.5-.7-.5h-.5a1.2 1.2 0 0 0-.8.4 3.5 3.5 0 0 0-1.1 2.6c0 1.5 1.1 3 1.3 3.2a13 13 0 0 0 5 4.4c2 .9 2.8.9 3.8.8a3 3 0 0 0 2-1.4c.3-.5.3-1 .2-1.1-.1-.2-.3-.2-.6-.4ZM12 2A10 10 0 0 0 2 12a10 10 0 0 0 1.5 5.3L2 22l4.8-1.5a10 10 0 0 0 15.2-8.5A10 10 0 0 0 12 2Z" />
    </svg>
  )
}
{
  name === "check" && (
    <svg {...stroke}>
      <path d="M20 6 9 17l-5-5" />
    </svg>
  )
}
{
  name === "menu" && (
    <svg {...stroke}>
      <path d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  )
}
{
  name === "close" && (
    <svg {...stroke}>
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  )
}
