---
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon.astro";

const services = [
  {
    icon: "layout" as const,
    title: "Sites e landing pages",
    body: "Páginas modernas, responsivas e pensadas para apresentar marcas, serviços e projetos com clareza.",
  },
  {
    icon: "code" as const,
    title: "Sistemas web",
    body: "Aplicações sob medida com boa estrutura, organização de dados e experiência simples para o usuário.",
  },
  {
    icon: "palette" as const,
    title: "Interfaces e UI",
    body: "Layouts limpos, consistentes e pensados para transformar funcionalidades em experiências agradáveis.",
  },
  {
    icon: "wrench" as const,
    title: "Deploy e melhoria",
    body: "Publicação, ajustes de performance, responsividade e evolução contínua do projeto.",
  },
];
---

<section class="section">
  <div class="site-container">
    <SectionHeader
      eyebrow="O que eu faço"
      title="Crio produtos digitais que unem código, design e objetivo."
      subtitle="Meu foco é desenvolvimento web e mobile. Em paralelo apoio design, conteúdo visual, edição de vídeo e testes manuais."
    />

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service, i) => (
          <article
            class="card card-hover reveal"
            style={`transition-delay: ${i * 60}ms`}
          >
            <span class="inline-flex size-10 items-center justify-center rounded-lg border border-border bg-surface-2 text-accent">
              <Icon name={service.icon} size={18} />
            </span>
            <h3 class="text-base font-semibold text-fg">{service.title}</h3>
            <p class="text-sm leading-relaxed text-muted">{service.body}</p>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-8 flex justify-center">
      <a href="/servicos" class="button button-secondary">
        Ver todos os serviços
        <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</section>
